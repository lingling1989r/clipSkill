# Copy this file to .env and fill in your token
#
#   cp .env.example .env
#
# IMPORTANT:
# - Keep your .env private (it contains a secret token)
# - Do NOT commit .env to git

# Required: Personal Access Token (create one at /tokens)
AUDIO_SKILL_TOKEN=

# Optional: backend base URL
AUDIO_SKILL_BACKEND_URL=http://localhost:3001

# Optional: default language for run.mjs (can also pass --language)
AUDIO_SKILL_LANGUAGE=zh
