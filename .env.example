# Copy this file to .env and fill in your token.
#
#   cp .env.example .env
#
# IMPORTANT:
# - Keep your .env file private — it contains a secret token.
# - Do NOT commit .env to git (it is already in .gitignore).

# ── Required ──────────────────────────────────────────────────────────
# Personal Access Token from podaha.com
# Get one at: https://podaha.com/tokens (register first if needed)
CLIP_SKILL_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────
# Backend base URL — defaults to the hosted PodAha API.
# Only change this if you are running PodAha locally.
CLIP_SKILL_BACKEND_URL=https://api.podaha.com

# Frontend base URL for the confirmation workspace.
# Local example: http://localhost:3000
CLIP_SKILL_FRONTEND_URL=https://podaha.com

# Default transcription language (can also be overridden with --language flag).
CLIP_SKILL_LANGUAGE=zh
